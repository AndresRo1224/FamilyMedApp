# template de variables de entorno - copiar este archivo a .env y poner los valores reales

# conexion a MongoDB Atlas (cluster privado)
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster.xxxxx.mongodb.net/familymed?retryWrites=true&w=majority

# clave secreta de Django (generar una aleatoria larga para produccion)
DJANGO_SECRET_KEY=cambiar-por-una-clave-secreta-aleatoria-larga

# modo debug (True solo en desarrollo)
DJANGO_DEBUG=True

# hosts permitidos separados por coma
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
